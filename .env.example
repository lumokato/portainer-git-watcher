PORTAINER_URL=https://your-portainer.tailnet.example
PORTAINER_API_KEY=replace-with-your-portainer-api-key

# Optional: limit monitoring to specific endpoints, stack names, or branches.
# Leave empty to auto-discover all Git stacks visible to the API key.
PORTAINER_ENDPOINT_IDS=
STACK_INCLUDE=
STACK_EXCLUDE=
BRANCH_INCLUDE=main

# Optional GitHub token for private repositories or higher rate limits.
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

POLL_INTERVAL_SECONDS=180
SKIP_INITIAL_REDEPLOY=true
REDEPLOY_PULL_IMAGE=true
REDEPLOY_PRUNE=false
LOG_LEVEL=INFO
